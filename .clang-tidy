# ODAI SDK Clang-Tidy Configuration
# Enforces naming conventions per style guide

Checks: >
  -*,
  cppcoreguidelines-*,
  bugprone-*,
  clang-analyzer-*,
  performance-*,
  readability-*,
  google-runtime-int

CheckOptions:
  # Functions: lower_case
  - key: readability-identifier-naming.FunctionCase
    value: lower_case

  # Variables: lower_case  
  - key: readability-identifier-naming.VariableCase
    value: lower_case

  # Parameters: lower_case
  - key: readability-identifier-naming.ParameterCase
    value: lower_case

  - key: readability-identifier-naming.ConstantParameterCase
    value: lower_case

  - key: readability-identifier-naming.ConstantPointerParameterCase
    value: lower_case

  # Classes: CamelCase
  - key: readability-identifier-naming.ClassCase
    value: CamelCase

  # Structs: CamelCase (or c_ prefix for C types)
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.StructIgnoredRegexp
    value: "^c_.*"

  # Enums: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase

  # Enum constants: UPPER_CASE
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE

  # Type aliases: CamelCase (or c_ prefix for C types)
  - key: readability-identifier-naming.TypedefCase
    value: CamelCase
  - key: readability-identifier-naming.TypedefIgnoredRegexp
    value: "^c_.*"
  - key: readability-identifier-naming.TypeAliasCase
    value: CamelCase
  - key: readability-identifier-naming.TypeAliasIgnoredRegexp
    value: "^c_.*"

  # Member variables: m_ prefix + camelBack
  - key: readability-identifier-naming.MemberCase
    value: camelBack
  - key: readability-identifier-naming.MemberPrefix
    value: m_

  # Struct Members: camelBack (overrides MemberCase for structs)
  - key: readability-identifier-naming.StructMemberCase
    value: camelBack
  - key: readability-identifier-naming.StructMemberPrefix
    value: ''

  # Constants: UPPER_CASE

  - key: readability-identifier-naming.ClassConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.EnumConstantCase
    value: UPPER_CASE
  - key: readability-identifier-naming.ConstexprVariableCase
    value: UPPER_CASE

  # Fallback Constants : lower_case (for any constants not covered by the above)
  - key: readability-identifier-naming.ConstantCase
    value: lower_case

  # Macros: UPPER_CASE
  # - key: readability-identifier-naming.MacroDefinitionCase
    # value: UPPER_CASE

  # Namespaces: lower_case
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case

  # Enforce that abstract classes (interfaces) start with 'I'
  - key: readability-identifier-naming.AbstractClassPrefix
    value: I
  
  # Enforce CamelCase for the rest of the name
  - key: readability-identifier-naming.AbstractClassCase
    value: CamelCase
